{
  "version": 2,
  "buildCommand": "pip install -r requirements.txt && python scripts/build_registry.py --embed-prompts || echo 'using committed registry.json'",
  "installCommand": "pip install -r requirements.txt",
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ],
  "env": {
    "PYTHONPATH": "."
  },
  "functions": {
    "api/index.py": {
      "maxDuration": 60,
      "includeFiles": "{registry/**,data/locale_zh.json,static/**}"
    }
  }
}
